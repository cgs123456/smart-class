# 智云星课后端 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# docker-compose 会自动读取 .env 文件

# MySQL
MYSQL_URL=jdbc:mysql://mysql:3306/smart_class
MYSQL_USERNAME=smartclass_app
MYSQL_PASSWORD=your_mysql_root_password
MYSQL_APP_PASSWORD=your_mysql_app_password

# 用户默认密码（管理员创建用户时使用，请设置为强随机密码）
# USER_DEFAULT_PASSWORD=请设置为强随机密码
USER_DEFAULT_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Elasticsearch
ES_URIS=http://elasticsearch:9200
ES_USERNAME=
ES_PASSWORD=

# 腾讯云 COS
COS_ACCESS_KEY=your_cos_access_key
COS_SECRET_KEY=your_cos_secret_key

# 微信公众号
WX_MP_TOKEN=your_wx_mp_token
WX_MP_AES_KEY=your_wx_mp_aes_key
WX_MP_APP_ID=your_wx_mp_app_id
WX_MP_SECRET=your_wx_mp_secret

# 微信支付（回调验签）
WX_PAY_SIGN_KEY=your_wx_pay_sign_key

# Dify AI
DIFY_API_KEY=your_dify_api_key
DIFY_BASE_URL=your_dify_base_url

# Cookie 安全（生产环境设为 true）
COOKIE_SECURE=false

# JWT 密钥
JWT_SECRET=your_jwt_secret_key_at_least_32_chars

# Knife4j 接口文档（生产环境建议关闭）
KNIFE4J_ENABLE=false
KNIFE4J_BASIC_ENABLE=false
KNIFE4J_USERNAME=
KNIFE4J_PASSWORD=

# CORS 允许的来源（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=https://smartclass.cgs.cn
